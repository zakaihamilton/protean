{
  "$schema": "https://biomejs.dev/schemas/2.4.14/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "files": {
    "includes": [
      "src/**/*.js",
      "src/**/*.res.js",
      "src/**/*.jsx",
      "src/**/*.ts",
      "src/**/*.tsx",
      "app/**/*.js",
      "app/**/*.jsx",
      "*.js",
      "*.json"
    ]
  },
  "overrides": [
    {
      "includes": ["**/*.js"],
      "javascript": {
        "parser": {
          "jsxEverywhere": true
        }
      }
    }
  ]
}
